

CREATE OR REPLACE FUNCTION array_intersect(t1 anyarray, t2 anyarray)
    RETURNS anyarray AS
$$

BEGIN
    EXCEPTION WHEN OTHERS
    THEN
    RETURN NULL;

END;
$$
LANGUAGE plpgsql;

